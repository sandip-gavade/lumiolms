// Lumio LMS — Prisma schema
// Multi-tenant B2B SaaS. Every tenant-scoped model carries `tenantId` and MUST be filtered
// by it on every query. In the app layer this is enforced centrally via a Prisma Client
// Extension (see src/prisma/prisma.service.ts), not left to individual queries — see
// docs/requirements.md NFR-3.7. Composite indexes are led by `tenantId` throughout so a
// single large tenant's query volume can never degrade another tenant's latency (NFR-1.4).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

// ─────────────────────────────────────────────────────────────────────────
// Tenancy & platform billing
// ─────────────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

model Tenant {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  subdomain    String       @unique
  customDomain String?      @unique @map("custom_domain")
  logoUrl      String?      @map("logo_url")
  primaryColor String?      @map("primary_color")
  status       TenantStatus @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  memberships       Membership[]
  subscription      TenantSubscription?
  categories        Category[]
  courses           Course[]
  carts             Cart[]
  coupons           Coupon[]
  orders            Order[]
  enrollments       Enrollment[]
  payoutEntries     InstructorPayoutLedgerEntry[]
  lectureProgress   LectureProgress[]
  notes             Note[]
  questions         Question[]
  certificates      Certificate[]
  announcements     Announcement[]
  notifications     Notification[]
  notificationPrefs NotificationPreference[]
  auditLogs         AuditLog[]
  reviews           Review[]

  @@map("tenants")
}

enum SubscriptionPlanCode {
  STARTER
  GROWTH
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

// Platform-defined plan catalog (few rows, not tenant-scoped).
model SubscriptionPlan {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         SubscriptionPlanCode @unique
  name         String
  priceCentsMo Int                  @map("price_cents_monthly")
  seatLimit    Int?                 @map("seat_limit")
  features     Json                 @default("{}")
  createdAt    DateTime             @default(now()) @map("created_at")

  subscriptions TenantSubscription[]

  @@map("subscription_plans")
}

// One tenant ↔ one active subscription. This is the org's bill to Lumio — independent of
// end-user course purchases, which live in Order/OrderItem below.
model TenantSubscription {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String             @unique @map("tenant_id") @db.Uuid
  planId               String             @map("plan_id") @db.Uuid
  status               SubscriptionStatus @default(TRIALING)
  seats                Int                @default(1)
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("tenant_subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────
// Users, membership, auth
// ─────────────────────────────────────────────────────────────────────────

enum MembershipRole {
  STUDENT
  INSTRUCTOR
  ORG_ADMIN
}

enum MembershipStatus {
  ACTIVE
  SUSPENDED
}

// Global identity — one row per human, independent of any tenant.
model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  googleId        String?   @unique @map("google_id")
  name            String
  avatarUrl       String?   @map("avatar_url")
  isSuperAdmin    Boolean   @default(false) @map("is_super_admin")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  memberships        Membership[]
  refreshTokens      RefreshToken[]
  passwordResets     PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
  carts              Cart[]
  orders             Order[]
  enrollments        Enrollment[]
  reviews            Review[]
  lectureProgress    LectureProgress[]
  notes              Note[]
  questions          Question[]
  answers            Answer[]
  certificates       Certificate[]
  notifications      Notification[]
  notificationPrefs  NotificationPreference[]
  payoutEntries      InstructorPayoutLedgerEntry[]
  auditLogsAsActor   AuditLog[]
  coursesTaught      Course[]

  @@map("users")
}

// A user's standing in one tenant. A user can hold more than one role in the same tenant
// (e.g. STUDENT + INSTRUCTOR) via two rows, and different roles across different tenants.
model Membership {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  role      MembershipRole
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, role])
  @@index([tenantId, role])
  @@map("memberships")
}

// Refresh-token rotation store; access tokens are stateless JWTs and not persisted.
model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tenantId  String?   @map("tenant_id") @db.Uuid // active tenant context for this session
  tokenHash String    @unique @map("token_hash")
  userAgent String?   @map("user_agent")
  ip        String?
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────────────────

// tenantId = null → platform default category, cloned/inherited by tenants that don't
// define their own (FR-6.3 / FR-7.4).
model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String?  @map("tenant_id") @db.Uuid
  name      String
  slug      String
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courses Course[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("categories")
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum CourseStatus {
  DRAFT
  SUBMITTED
  PUBLISHED
  ARCHIVED
}

model Course {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  instructorId String       @map("instructor_id") @db.Uuid
  categoryId   String?      @map("category_id") @db.Uuid
  title        String
  slug         String
  shortDesc    String       @map("short_desc")
  longDesc     String       @map("long_desc")
  outcomes     String[]     @default([]) // "What you'll learn" bullets
  level        CourseLevel  @default(ALL_LEVELS)
  priceCents   Int          @map("price_cents")
  currency     String       @default("usd")
  thumbnailUrl String?      @map("thumbnail_url")
  status       CourseStatus @default(DRAFT)
  publishedAt  DateTime?    @map("published_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Populated by a DB trigger from title/shortDesc/longDesc for Postgres full-text search
  // (FR-2.1). Prisma can't author tsvector generated columns, so this column + its GIN
  // index + the refresh trigger are added in a hand-written SQL migration.
  searchVector Unsupported("tsvector")? @map("search_vector")

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructor    User            @relation(fields: [instructorId], references: [id])
  category      Category?       @relation(fields: [categoryId], references: [id])
  sections      CourseSection[]
  reviews       Review[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  enrollments   Enrollment[]
  questions     Question[]
  certificates  Certificate[]
  announcements Announcement[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, categoryId])
  @@map("courses")
}

model CourseSection {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  title     String
  position  Int
  createdAt DateTime @default(now()) @map("created_at")

  course   Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lectures Lecture[]

  @@index([courseId, position])
  @@map("course_sections")
}

model Lecture {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId       String   @map("section_id") @db.Uuid
  title           String
  position        Int
  durationSeconds Int      @map("duration_seconds")
  videoAssetId    String?  @map("video_asset_id") // Mux/Cloudflare Stream asset id
  transcriptUrl   String?  @map("transcript_url")
  isPreview       Boolean  @default(false) @map("is_preview")
  createdAt       DateTime @default(now()) @map("created_at")

  section   CourseSection     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  resources LectureResource[]
  progress  LectureProgress[]
  notes     Note[]
  questions Question[]

  @@index([sectionId, position])
  @@map("lectures")
}

enum LectureResourceType {
  SOURCE_CODE
  EXERCISE_FILE
  ATTACHMENT
}

model LectureResource {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lectureId String              @map("lecture_id") @db.Uuid
  label     String
  fileUrl   String              @map("file_url")
  type      LectureResourceType
  createdAt DateTime            @default(now()) @map("created_at")

  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@index([lectureId])
  @@map("lecture_resources")
}

model Review {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  rating    Int      @db.SmallInt // 1-5, enforced in application layer
  title     String?
  body      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([tenantId, courseId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────
// Commerce
// ─────────────────────────────────────────────────────────────────────────

model Cart {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  CartItem[]

  @@unique([tenantId, userId]) // one active cart per user per tenant
  @@map("carts")
}

model CartItem {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId   String   @map("cart_id") @db.Uuid
  courseId String   @map("course_id") @db.Uuid
  addedAt  DateTime @default(now()) @map("added_at")

  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([cartId, courseId])
  @@map("cart_items")
}

enum DiscountType {
  PERCENT
  FIXED
}

model Coupon {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  code           String
  discountType   DiscountType @map("discount_type")
  discountValue  Int          @map("discount_value") // percent (0-100) or cents, per discountType
  startsAt       DateTime     @map("starts_at")
  endsAt         DateTime     @map("ends_at")
  maxRedemptions Int?         @map("max_redemptions")
  redeemedCount  Int          @default(0) @map("redeemed_count")
  createdAt      DateTime     @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([tenantId, code])
  @@index([tenantId, endsAt])
  @@map("coupons")
}

enum OrderStatus {
  PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

model Order {
  id                    String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String      @map("tenant_id") @db.Uuid
  userId                String      @map("user_id") @db.Uuid
  couponId              String?     @map("coupon_id") @db.Uuid
  status                OrderStatus @default(PENDING)
  subtotalCents         Int         @map("subtotal_cents")
  discountCents         Int         @default(0) @map("discount_cents")
  totalCents            Int         @map("total_cents")
  currency              String      @default("usd")
  stripePaymentIntentId String?     @unique @map("stripe_payment_intent_id")
  invoiceUrl            String?     @map("invoice_url")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon  Coupon?     @relation(fields: [couponId], references: [id])
  items   OrderItem[]
  refunds Refund[]

  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
  @@map("orders")
}

// Snapshot of price at purchase time — course.priceCents may change later.
model OrderItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  priceCents Int      @map("price_cents")
  createdAt  DateTime @default(now()) @map("created_at")

  order       Order                        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  course      Course                       @relation(fields: [courseId], references: [id])
  enrollment  Enrollment?
  refunds     Refund[]
  payoutEntry InstructorPayoutLedgerEntry?

  @@unique([orderId, courseId])
  @@map("order_items")
}

model Enrollment {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  courseId    String    @map("course_id") @db.Uuid
  orderItemId String?   @unique @map("order_item_id") @db.Uuid
  enrolledAt  DateTime  @default(now()) @map("enrolled_at")
  completedAt DateTime? @map("completed_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])

  @@unique([userId, courseId])
  @@index([tenantId, courseId])
  @@map("enrollments")
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSED
}

model Refund {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId           String       @map("order_id") @db.Uuid
  orderItemId       String?      @map("order_item_id") @db.Uuid
  amountCents       Int          @map("amount_cents")
  reason            String?
  status            RefundStatus @default(REQUESTED)
  requestedByUserId String       @map("requested_by_user_id") @db.Uuid
  processedByUserId String?      @map("processed_by_user_id") @db.Uuid
  createdAt         DateTime     @default(now()) @map("created_at")
  processedAt       DateTime?    @map("processed_at")

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])

  @@index([orderId])
  @@map("refunds")
}

enum PayoutStatus {
  PENDING
  PAID
}

model InstructorPayoutLedgerEntry {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  instructorId String       @map("instructor_id") @db.Uuid
  orderItemId  String       @unique @map("order_item_id") @db.Uuid
  amountCents  Int          @map("amount_cents")
  status       PayoutStatus @default(PENDING)
  createdAt    DateTime     @default(now()) @map("created_at")
  paidAt       DateTime?    @map("paid_at")

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructor User      @relation(fields: [instructorId], references: [id])
  orderItem  OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([tenantId, instructorId, status])
  @@map("instructor_payout_ledger_entries")
}

// ─────────────────────────────────────────────────────────────────────────
// Learning experience
// ─────────────────────────────────────────────────────────────────────────

model LectureProgress {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  lectureId       String    @map("lecture_id") @db.Uuid
  positionSeconds Int       @default(0) @map("position_seconds")
  completedAt     DateTime? @map("completed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@unique([userId, lectureId])
  @@index([tenantId, userId])
  @@map("lecture_progress")
}

model Note {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  lectureId        String   @map("lecture_id") @db.Uuid
  timestampSeconds Int      @map("timestamp_seconds")
  body             String
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, lectureId])
  @@map("notes")
}

model Question {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  lectureId String?  @map("lecture_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lecture Lecture? @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([tenantId, courseId])
  @@map("questions")
}

model Answer {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId         String   @map("question_id") @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  body               String
  isInstructorAnswer Boolean  @default(false) @map("is_instructor_answer")
  createdAt          DateTime @default(now()) @map("created_at")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("answers")
}

model Certificate {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  courseId          String   @map("course_id") @db.Uuid
  certificateNumber String   @unique @map("certificate_number")
  pdfUrl            String   @map("pdf_url")
  issuedAt          DateTime @default(now()) @map("issued_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("certificates")
}

model Announcement {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  courseId     String   @map("course_id") @db.Uuid
  instructorId String   @map("instructor_id") @db.Uuid
  title        String
  body         String
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([tenantId, courseId])
  @@map("announcements")
}

enum NotificationType {
  QA_REPLY
  COURSE_ANNOUNCEMENT
  SALE
  RESUME_REMINDER
  CERTIFICATE_READY
}

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  payload   Json             @default("{}")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, readAt])
  @@map("notifications")
}

model NotificationPreference {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String           @map("tenant_id") @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  type         NotificationType
  emailEnabled Boolean          @default(true) @map("email_enabled")
  inAppEnabled Boolean          @default(true) @map("in_app_enabled")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, type])
  @@map("notification_preferences")
}

// ─────────────────────────────────────────────────────────────────────────
// Audit (admin actions + super-admin impersonation)
// ─────────────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid // null = platform-level/super-admin action
  actorUserId String   @map("actor_user_id") @db.Uuid
  action      String // e.g. "user.suspend", "course.unpublish", "refund.approve"
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User    @relation(fields: [actorUserId], references: [id])

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
